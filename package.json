{
  "name": "gren-packages",
  "type": "module",
  "version": "6.0.3",
  "description": "The server powering package.gren-lang.org",
  "keywords": [
    "gren",
    "lang",
    "language",
    "doc",
    "documentation",
    "package",
    "preview"
  ],
  "main": "index.js",
  "bin": {
    "gren-package-server": "index.js",
    "gren-doc-preview": "bin/gren-doc-preview.js"
  },
  "imports": {
    "#src/*": "./src/*.js",
    "#db/*": "./src/db/*.js",
    "#utils/*": "./src/utils/*.js",
    "#routes/*": "./src/routes/*.js"
  },
  "scripts": {},
  "author": "Robin Heggelund Hansen",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/gren-lang/package.gren-lang.org/issues"
  },
  "homepage": "https://packages.gren-lang.org",
  "dependencies": {
    "ejs": "^5.0.1",
    "gren-lang": "^0.6.5",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.3.0",
    "koa-conditional-get": "^3.0.0",
    "koa-static": "^5.0.0",
    "@koa/router": "^15.4.0",
    "markdown-it": "14.1.1",
    "@markslides/markdown-it-mermaid": "^0.4.6",
    "semver": "^7.3.8",
    "sqlite3": "^6.0.1",
    "xdg-basedir": "^5.1.0"
  }
